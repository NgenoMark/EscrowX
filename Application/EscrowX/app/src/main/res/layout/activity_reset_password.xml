<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="#F7F9FC">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp"
        android:gravity="center_horizontal">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Reset Password"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="#002066"
            android:layout_marginTop="40dp"
            android:layout_marginBottom="12dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Step 1: Request OTP. Step 2: Confirm with OTP and new password."
            android:textColor="#666666"
            android:layout_marginBottom="24dp" />

        <EditText
            android:id="@+id/etResetPhone"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:hint="Phone Number (+2547XXXXXXXX)"
            android:inputType="phone"
            android:background="@android:drawable/editbox_background"
            android:padding="12dp"
            android:layout_marginBottom="16dp" />

        <Button
            android:id="@+id/btnRequestOtp"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="Request OTP"
            android:backgroundTint="#002066"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            android:layout_marginBottom="16dp" />

        <EditText
            android:id="@+id/etResetOtp"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:hint="OTP Code"
            android:inputType="number"
            android:maxLength="6"
            android:background="@android:drawable/editbox_background"
            android:padding="12dp"
            android:layout_marginBottom="16dp" />

        <EditText
            android:id="@+id/etResetNewPassword"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:hint="New Password"
            android:inputType="textPassword"
            android:background="@android:drawable/editbox_background"
            android:padding="12dp"
            android:layout_marginBottom="20dp" />

        <Button
            android:id="@+id/btnConfirmReset"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="Confirm Reset"
            android:backgroundTint="#0A7D44"
            android:textColor="#FFFFFF"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvResetBackToLogin"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Back to Login"
            android:textColor="#666666"
            android:layout_marginTop="24dp"
            android:padding="8dp" />

    </LinearLayout>
</ScrollView>

