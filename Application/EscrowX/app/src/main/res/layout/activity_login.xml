<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="@color/auth_screen_bg">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp"
        android:gravity="center_horizontal">

    <ImageView
        android:id="@+id/ivLogo"
        android:layout_width="64dp"
        android:layout_height="64dp"
        android:layout_marginTop="40dp"
        android:src="@drawable/ic_shield_lock"
        android:contentDescription="EscrowX Security Logo" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/app_name"
        android:textSize="24sp"
        android:textStyle="bold"
        android:textColor="@color/auth_title_text"
        android:layout_marginTop="16dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/app_tagline"
        android:textAlignment="center"
        android:textColor="@color/auth_muted_text"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="32dp"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="@drawable/bg_auth_tab_container"
        android:padding="4dp"
        android:layout_marginBottom="24dp"
        style="?android:attr/buttonBarStyle">

        <Button
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/label_login"
            android:backgroundTint="@color/auth_card_bg"
            android:textColor="@color/auth_title_text"
            style="?android:attr/buttonBarButtonStyle"/>

        <Button
            android:id="@+id/btnTabSignUp"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/label_sign_up"
            android:backgroundTint="@color/auth_input_bg"
            android:textColor="@color/auth_muted_text"
            style="?android:attr/buttonBarButtonStyle"/>
    </LinearLayout>

    <EditText
        android:id="@+id/etLoginIdentifier"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:hint="@string/hint_login_identifier"
        android:inputType="textEmailAddress"
        android:autofillHints="emailAddress"
        android:background="@drawable/bg_auth_input"
        android:textColor="@color/auth_input_text"
        android:textColorHint="@color/auth_input_hint"
        android:padding="12dp"
        android:layout_marginBottom="16dp"/>

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:layout_marginBottom="4dp">

        <EditText
            android:id="@+id/etLoginPassword"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:hint="@string/hint_password"
            android:inputType="textPassword"
            android:autofillHints="password"
            android:background="@drawable/bg_auth_input"
            android:textColor="@color/auth_input_text"
            android:textColorHint="@color/auth_input_hint"
            android:paddingStart="12dp"
            android:paddingEnd="48dp"
            android:paddingTop="12dp"
            android:paddingBottom="12dp"/>

        <ImageButton
            android:id="@+id/btnToggleLoginPassword"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_gravity="end|center_vertical"
            android:layout_marginEnd="6dp"
            android:background="@android:color/transparent"
            android:contentDescription="Show password"
            android:padding="8dp"
            android:src="@drawable/ic_visibility_off"
            android:tint="@color/auth_muted_text" />
    </FrameLayout>

    <TextView
        android:id="@+id/tvForgotPassword"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/btn_forgot_password"
        android:textColor="@color/auth_link_text"
        android:textStyle="bold"
        android:layout_gravity="end"
        android:layout_marginTop="12dp"
        android:layout_marginBottom="24dp"/>

    <Button
        android:id="@+id/btnLoginContinue"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:text="@string/btn_continue"
        android:backgroundTint="@color/brand_primary"
        android:textColor="#FFFFFF"
        android:textStyle="bold"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/label_or_continue"
        android:textSize="12sp"
        android:textColor="@color/auth_muted_text"
        android:layout_marginVertical="24dp"/>

    <Button
        android:id="@+id/btnGoogleLogin"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:text="@string/btn_google"
        android:backgroundTint="@color/auth_input_bg"
        android:textColor="@color/auth_body_text"
        style="@style/Widget.AppCompat.Button.Colored"/>

    </LinearLayout>

</ScrollView>
