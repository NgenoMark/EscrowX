<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- Permissions -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.CAMERA" />
    <uses-permission android:name="android.permission.READ_MEDIA_IMAGES" />
    <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE" android:maxSdkVersion="32" />

    <!-- Camera hardware feature -->
    <uses-feature android:name="android.hardware.camera" android:required="false" />
    <uses-feature android:name="android.hardware.camera.autofocus" android:required="false" />

    <application
        android:name=".EscrowXApp"
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:usesCleartextTraffic="true"
        android:supportsRtl="true"
        android:theme="@style/Theme.EscrowX"
        tools:targetApi="31"
        android:networkSecurityConfig="@xml/network_security_config"
        android:requestLegacyExternalStorage="true">

        <!-- File Provider for Camera/Gallery -->
        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths" />
        </provider>

        <!-- LAUNCHER ACTIVITY -->
        <activity
            android:name=".auth.SplashActivity"
            android:exported="true"
            android:screenOrientation="unspecified"
            android:theme="@style/Theme.EscrowX.SplashFull">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <activity
            android:name=".auth.LoginActivity"
            android:exported="false"
            android:screenOrientation="unspecified"
            android:windowSoftInputMode="adjustResize">
        </activity>

        <!-- AUTH ACTIVITIES -->
        <activity
            android:name=".auth.SignUpActivity"
            android:exported="false"
            android:screenOrientation="unspecified"
            android:windowSoftInputMode="adjustResize" />

        <activity
            android:name=".auth.VerificationActivity"
            android:exported="false"
            android:screenOrientation="unspecified"
            android:windowSoftInputMode="adjustResize" />

        <activity
            android:name=".auth.ResetPasswordActivity"
            android:exported="false"
            android:screenOrientation="unspecified"
            android:windowSoftInputMode="adjustResize" />

        <!-- DASHBOARD ACTIVITIES -->
        <activity
            android:name=".dash.BuyerDashboardActivity"
            android:exported="false"
            android:screenOrientation="unspecified" />

        <activity
            android:name=".dash.CreateEscrowActivity"
            android:exported="false"
            android:screenOrientation="unspecified" />

        <activity
            android:name=".dash.ProfileActivity"
            android:exported="false"
            android:screenOrientation="unspecified" />

        <activity
            android:name=".dash.DisputeCenterActivity"
            android:exported="false"
            android:screenOrientation="unspecified" />

        <activity
            android:name=".dash.RaiseDisputeActivity"
            android:exported="false"
            android:screenOrientation="unspecified" />

        <activity
            android:name=".dash.DisputeDetailsActivity"
            android:exported="false"
            android:screenOrientation="unspecified" />

        <activity
            android:name=".dash.TransactionsActivity"
            android:exported="false"
            android:screenOrientation="unspecified" />

        <activity
            android:name=".dash.SettingsActivity"
            android:exported="false"
            android:screenOrientation="unspecified" />

        <activity
            android:name=".dash.TrackFinancesActivity"
            android:exported="false"
            android:screenOrientation="unspecified" />

        <activity
            android:name=".dash.PaymentActivity"
            android:exported="false"
            android:screenOrientation="unspecified" />
        <activity
            android:name=".dash.BuyerTransactionDetailActivity"
            android:exported="false" />


        <!-- Change Password Activities -->
        <activity
            android:name=".auth.ChangePasswordVerificationActivity"
            android:exported="false"
            android:screenOrientation="unspecified" />

        <activity
            android:name=".auth.CreateNewPasswordActivity"
            android:exported="false"
            android:screenOrientation="unspecified" />

        <!-- SELLER ACTIVITIES -->
        <activity
            android:name=".seller.SellerDashboardActivity"
            android:exported="false"
            android:screenOrientation="unspecified" />

        <activity
            android:name=".seller.CreatePaymentLinkActivity"
            android:exported="false"
            android:screenOrientation="unspecified" />

        <activity
            android:name=".seller.LinkGeneratedActivity"
            android:exported="false"
            android:screenOrientation="unspecified" />

        <activity
            android:name=".seller.IncomingEscrowsActivity"
            android:exported="false"
            android:screenOrientation="unspecified" />

        <activity
            android:name=".seller.RejectRequestActivity"
            android:exported="false"
            android:screenOrientation="unspecified" />

        <activity
            android:name=".seller.RequestAcceptedActivity"
            android:exported="false"
            android:screenOrientation="unspecified" />

        <activity
            android:name=".seller.RequestDeclinedActivity"
            android:exported="false"
            android:screenOrientation="unspecified" />

        <activity
            android:name=".dash.TransactionDetailsActivity"
            android:exported="false"
            android:screenOrientation="unspecified" />
        <activity
            android:name=".seller.SellerActiveEscrowsActivity"
            android:exported="false"
            android:screenOrientation="unspecified" />

        <activity
            android:name=".seller.SellerTransactionDetailActivity"
            android:exported="false"
            android:screenOrientation="unspecified" />

        <activity
            android:name="com.yalantis.ucrop.UCropActivity"
            android:exported="false"
            android:screenOrientation="portrait"
            android:theme="@style/Theme.AppCompat.Light.NoActionBar" />

    </application>

</manifest>